# ─────────────────────────────────────────────────────────────
# n8n Production Stack — Environment Configuration
# Copy to .env and fill in all values marked REQUIRED.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n_admin
POSTGRES_PASSWORD=                        # REQUIRED — superuser for init only, generate: openssl rand -base64 24
POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=               # REQUIRED — used by n8n app itself, generate: openssl rand -base64 24

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=                           # REQUIRED — generate: openssl rand -base64 24

# ── n8n Core ────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=                       # REQUIRED — generate ONCE: openssl rand -hex 32
                                           # Back this up outside the volume. Losing it makes all
                                           # stored credentials in n8n permanently unrecoverable.
N8N_HOST=n8n.yourdomain.com               # REQUIRED — public hostname
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.yourdomain.com/   # REQUIRED — trailing slash matters
TIMEZONE=Asia/Dhaka

# ── Task Runners ────────────────────────────────────────────
N8N_RUNNERS_AUTH_TOKEN=                   # REQUIRED — generate: openssl rand -hex 32
                                           # Shared secret between n8n/worker and their runner sidecars.

# ── Worker Scaling ──────────────────────────────────────────
N8N_WORKER_REPLICAS=2                     # Keep n8n-worker and n8n-worker-runner counts equal

# ── Logging ─────────────────────────────────────────────────
N8N_LOG_LEVEL=info                        # debug | info | warn | error
N8N_LOG_OUTPUT=console

# ── SMTP (optional — for user invite/password-reset emails) ─
N8N_SMTP_HOST=
N8N_SMTP_PORT=587
N8N_SMTP_USER=
N8N_SMTP_PASS=
N8N_SMTP_SENDER=n8n@yourdomain.com
